# YouTube Shorts Automation - Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: YouTube API
# ============================================

# Get from: https://console.cloud.google.com
YOUTUBE_API_KEY="your_youtube_api_key_here"
CHANNEL_ID="your_channel_id_here"

# ============================================
# REQUIRED: Gemini AI (for metadata generation)
# ============================================

# Get from: https://aistudio.google.com/
GEMINI_API_KEY="your_gemini_api_key_here"

# ============================================
# OPTIONAL: Telegram Integration
# ============================================

TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
TELEGRAM_CHAT_ID="your_telegram_chat_id_here"

# ============================================
# OPTIONAL: Social Media Integration
# ============================================

# Twitter/X Credentials
X_CLIENT_ID="your_x_client_id_here"
X_CLIENT_SECRET="your_x_client_secret_here"

# Instagram Credentials
INSTA_APP_ID="your_insta_app_id_here"
INSTA_APP_SECRET="your_insta_app_secret_here"

# ============================================
# NOTES
# ============================================

# 1. NEVER commit this file to git or share it
# 2. Add to .gitignore: .env
# 3. Only GEMINI_API_KEY is required for GUI
# 4. Keep this file secure (chmod 600 on Unix)
# 5. Ensure no trailing spaces or quotes
